# ---------------------------------------------------------------------------
# Tools Jamaica API — environment TEMPLATE
# Copy to `.env` (git-ignored) and fill in. NEVER put real secrets in this file.
# The server zod-validates `.env` at boot and refuses to start if misconfigured
# (see src/config/env.ts).
# ---------------------------------------------------------------------------

PORT=3000
NODE_ENV=development

# Supabase project (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=      # server-only secret, NEVER shipped to the client
SUPABASE_ANON_KEY=              # server-only; used for GoTrue auth calls
SUPABASE_JWT_SECRET=            # HS256 legacy secret (only if project signs HS256)

# Signs the session cookies (long random string, e.g. `openssl rand -hex 32`)
COOKIE_SECRET=

# Production base URL (absolute URLs + secure/same-origin cookies).
APP_BASE_URL=https://tools-jamaica-production.up.railway.app

# Dev-only CORS when running Vite separately (unset in production).
WEB_ORIGIN=http://localhost:5173
